{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/index.ts": {
      "includeFiles": [
        "server/**",
        "shared/**",
        "prisma/**",
        "node_modules/.prisma/**",
        "node_modules/@prisma/client/**"
      ]
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
